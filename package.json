{
  "name": "@cloudglab/mastergo-cli",
  "version": "1.0.0",
  "description": "MasterGo CLI and AI skill package for design DSL, D2C/C2D, metadata, and component workflow access",
  "homepage": "https://github.com/cloudglab/mastergo-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudglab/mastergo-cli.git"
  },
  "bugs": {
    "url": "https://github.com/cloudglab/mastergo-cli/issues"
  },
  "type": "module",
  "bin": {
    "mastergo": "bin/mastergo.js",
    "mastergo-cli": "bin/mastergo.js"
  },
  "files": [
    "assets",
    "bin",
    "skills",
    "design.md",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check bin/mastergo.js",
    "help": "node bin/mastergo.js help",
    "test": "node --test tests/*.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "mastergo",
    "cli",
    "skill",
    "design-to-code",
    "mastergo-api"
  ],
  "author": "Jeason",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "undici": "^6.21.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
